Notebook[{
Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{
   "The", " ", "first", " ", "step", " ", "in", " ", "this", " ", "process", 
    " ", "is", " ", "to", " ", "create", " ", "a", " ", "grid", " ", "of", 
    " ", "points", " ", "where", " ", "the", " ", "vector", " ", "field", " ",
     "will", " ", "be", " ", 
    RowBox[{"approximated", ".", " ", "If"}], " ", "you", " ", "reduce", " ", 
    "\"\<Pts\>\"", " ", "too", " ", "agressively"}], ",", " ", 
   RowBox[{"you", " ", "normally", " ", "get", " ", "a", " ", "terrible", " ", 
    RowBox[{"result", ".", " ", "Depending"}], " ", "on", " ", "the", " ", 
    "resolution", " ", "of", " ", "your", " ", "screen"}], ",", " ", 
   RowBox[{
   "you", " ", "may", " ", "need", " ", "to", " ", "expand", " ", "the", " ", 
    "grid", " ", "to", " ", "make", " ", "it", " ", "not", " ", "look", " ", 
    "weird", " ", 
    RowBox[{"(", 
     RowBox[{
     "The", " ", "screen", " ", "samples", " ", "at", " ", "the", " ", 
      "wrong", " ", "frequency", " ", "and", " ", "creates", " ", "bands"}], 
     ")"}]}]}], "*)"}]], "Input",
 CellChangeTimes->{{3.608418089264888*^9, 3.608418133776471*^9}, {
  3.608418728307654*^9, 3.608418772070939*^9}, {3.608419640241468*^9, 
  3.608419662136054*^9}}],

Cell[CellGroupData[{

